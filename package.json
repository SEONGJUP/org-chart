{
  "name": "seiim-landing-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node -e \"require('fs').rmSync('.next/cache',{recursive:true,force:true})\" && next dev --disable-source-maps -p 3001",
    "dev:local": "node -e \"require('fs').rmSync('.next/cache',{recursive:true,force:true})\" && next dev --disable-source-maps -p 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3001 -H 0.0.0.0",
    "serve:local": "next start -p 3001 -H 0.0.0.0",
    "preview:static": "node scripts/local-static-server.mjs",
    "preview:fresh": "node scripts/preview-fresh.mjs",
    "preview:hidden": "powershell -ExecutionPolicy Bypass -File scripts/start-preview-hidden.ps1",
    "smoke:css": "node scripts/smoke-css.mjs",
    "verify:ui": "npm run smoke:css",
    "lint": "eslint",
    "bot": "tsx src/bot/index.ts",
    "bot:deploy": "tsx src/bot/commands/deploy.ts"
  },
  "dependencies": {
    "@notionhq/client": "^5.9.0",
    "@react-three/fiber": "^9.4.0",
    "@tabler/icons-react": "^3.34.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "es-toolkit": "^1.39.10",
    "fiber": "^1.0.4",
    "html-to-image": "^1.11.13",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-fast-marquee": "^1.6.5",
    "shadergradient": "^1.3.5",
    "tailwind-merge": "^3.3.1",
    "tailwind-scrollbar": "^4.0.2",
    "three": "^0.181.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
